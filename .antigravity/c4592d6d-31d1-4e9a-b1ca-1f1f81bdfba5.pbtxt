320\271 \321\201\321\202\320\270\320\273\321\214 `Code`**:\n  - \320\222 \321\204\320\260\320\271\320\273\320\265 `mobile.css` \320\267\320\260\321\200\320\265\320\263\320\270\321\201\321\202\321\200\320\270\321\200\320\276\320\262\320\260\320\273 \320\275\320\276\320\262\321\213\320\265 \321\201\320\265\320\274\320\260\320\275\321\202\320\270\321\207\320\265\321\201\320\272\320\270\320\265 \320\264\320\270\320\267\320\260\320\271\320\275-\321\202\320\276\320\272\320\265\320\275\321\213:\n    - `--font-label-code-family: \"Google Sans Code\", var(--font-family-mono);`\n    - `--font-label-code-size: 14px;`\n    - `--font-label-code-weight: 500;`\n    - `--font-label-code-line-height: 16px;`\n    - `--font-label-code-tracking: 0;`\n  - \320\224\320\276\320\261\320\260\320\262\320\270\320\273 \321\201\320\273\321\203\320\266\320\265\320\261\320\275\321\213\320\271 \320\272\320\273\320\260\321\201\321\201 `.font-label-code` \320\262 `main.css`.\n- **\320\241\320\265\321\202\320\272\320\260 \320\270 \320\272\320\276\320\274\320\277\320\276\320\275\320\276\320\262\320\272\320\260 \321\202\320\265\320\263\320\276\320\262**:\n  - \320\236\320\261\320\265\321\200\320\275\321\203\320\273 \321\202\320\265\320\263\320\270 \320\262 \320\263\320\270\320\261\320\272\320\270\320\271 \320\272\320\276\320\275\321\202\320\265\320\271\320\275\320\265\321\200 `.work-card__tags-container`.\n  - \320\227\320\260\320\264\320\260\320\273 \320\276\321\202\321\201\321\202\321\203\320\277\321\213 \321\201\320\276\320\263\320\273\320\260\321\201\320\275\320\276 \320\262\320\260\321\210\320\270\320\274 \321\201\320\277\320\265\321\206\320\270\321\204\320\270\320\272\320\260\321\206\320\270\321\217\320\274 \320\270 \320\264\320\270\320\267\320\260\320\271\320\275-\321\202\320\276\320\272\320\265\320\275\320\260\320\274: `px: 12px` (`--spacing-component-px-sm`) \320\270 `py: 4px` (`--spacing-component-py-2xs`).\n  - \320\243\321\201\321\202\320\260\320\275\320\276\320\262\320\270\320\273 \321\200\320\260\321\201\321\201\321\202\320\276\321\217\320\275\320\270\320\265 \320\274\320\265\320\266\320\264\321\203 \321\202\320\265\320\263\320\260\320\274\320\270 `gap: 4px` (`--spacing-component-py-2xs`).\n- **\320\241\321\202\320\270\320\273\321\214\320\275\321\213\320\271 \321\200\320\260\320\267\320\264\320\265\320\273\320\270\321\202\320\265\320\273\321\214 `/`**:\n  - \320\240\320\265\320\260\320\273\320\270\320\267\320\276\320\262\320\260\320\273 \320\264\320\270\320\275\320\260\320\274\320\270\321\207\320\265\321\201\320\272\320\270\320\271 \320\277\320\260\321\200\321\201\320\270\320\275\320\263 \321\201\321\202\321\200\320\276\320\272\320\270 \321\202\320\265\320\263\320\276\320\262 \320\277\320\276 \321\201\320\270\320\274\320\262\320\276\320\273\321\203 `/` \320\270 \320\260\320\262\321\202\320\276\320\274\320\260\321\202\320\270\321\207\320\265\321\201\320\272\320\270\320\271 \321\200\320\265\320\275\320\264\320\265\321\200\320\270\320\275\320\263 \320\272\320\260\320\266\320\264\320\276\320\263\320\276 \321\215\320\273\320\265\320\274\320\265\320\275\321\202\320\260.\n  - \320\225\321\201\320\273\320\270 \321\202\320\265\320\263\320\276\320\262 \320\275\320\265\321\201\320\272\320\276\320\273\321\214\320\272\320\276, \320\274\320\265\320\266\320\264\321\203 \320\275\320\270\320\274\320\270 \320\260\320\272\320\272\321\203\321\200\320\260\321\202\320\275\320\276 \320\262\321\213\320\262\320\276\320\264\320\270\321\202\321\201\321\217 \321\200\320\260\320\267\320\264\320\265\320\273\320\270\321\202\320\265\320\273\321\214 `.work-card__tag-separator` \321\201\320\276 \321\201\321\202\320\270\320\273\321\214\320\275\321\213\320\274 \320\274\320\276\320\275\320\276\321\210\320\270\321\200\320\270\320\275\320\275\321\213\320\274 \320\276\321\204\320\276\321\200\320\274\320\273\320\265\320\275\320\270\320\265\320\274 \320\270 \320\274\321\217\320\263\320\272\320\276\320\271 \320\277\321\200\320\276\320\267\321\200\320\260\321\207\320\275\320\276\321\201\321\2